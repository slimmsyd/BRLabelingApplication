// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AccountType {
  LABELER
  QUALITY_CONTROL
  ADMIN
}

enum VideoStatus {
  ASSIGNED      // Video has been assigned to a user
  IN_PROGRESS   // User has picked up the video
  SUBMITTED     // User has submitted their work
  REVIEWED      // Quality control has reviewed
  COMPLETED     // Fully completed
}

enum LabelType {
  OFFENSE
  DEFENSE
  FOOTWORK
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  username         String             @unique
  password         String
  accountType      AccountType        @default(LABELER)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  
  // Relations
  videoAssignments VideoAssignment[]  // Videos assigned to this user
}

enum StorageProvider {
  SUPABASE
  S3
  HYBRID  // For videos split across providers
}

model Video {
  id          String             @id @default(cuid())
  
  // Storage location (provider-agnostic)
  storagePath      String        @unique  // e.g., "bivol_canelo/r3/cam1.mp4"
  storageProvider  StorageProvider @default(SUPABASE)
  
  // Fight Metadata (synced from storage)
  title       String                      // e.g., "Bivol v Canelo - R3"
  description String?                     // Full description
  boxer1      String                      // First boxer name
  boxer2      String                      // Second boxer name
  weightClass String?                     // e.g., "Welterweight"
  round       Int                         // Round number
  segment     String             @default("Seg 1")  // Segment identifier
  fightDate   DateTime                    // Date of the fight
  
  // Video Technical Details
  fps         Int                         // Frames per second
  numCameraViews Int                      // Number of camera angles (1-3)
  sourceUrls  Json                        // Array of public URLs (Supabase or S3/CloudFront)
  duration    Int?                        // Duration in seconds
  
  // Upload Tracking
  uploadedBy  String?                     // User ID who uploaded (optional)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  
  // Relations
  assignments VideoAssignment[]  // All assignments for this video
  
  @@index([storagePath])
  @@index([storageProvider])
  @@index([uploadedBy])
  @@index([fightDate])
}

model VideoAssignment {
  id            String       @id @default(cuid())
  videoId       String
  userId        String
  labelType     LabelType    // Type of labeling: Offense, Defense, or Footwork
  status        VideoStatus  @default(ASSIGNED)
  
  // Tracking timestamps
  assignedAt    DateTime     @default(now())
  pickedUpAt    DateTime?    // When user started working on it
  submittedAt   DateTime?    // When user submitted their work
  reviewedAt    DateTime?    // When QC reviewed it
  
  // Additional tracking
  notes         String?      // Any notes from the user or reviewer
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  // Relations
  video         Video        @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  events        Event[]      // Relation to events
  
  // User can be assigned same video for different label types
  @@unique([videoId, userId, labelType])
  @@index([userId])
  @@index([videoId])
  @@index([status])
  @@index([labelType])
}

model Event {
  id              String          @id @default(cuid())
  assignmentId    String
  assignment      VideoAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  
  // Event Data Fields
  startTime       String
  endTime         String
  boxer           String
  punchType       String
  hand            String
  target          String
  visibilityFlags String[]
  knockdown       Boolean
  punchQuality    String
  cam             String?
  stance          String?
  landed          Boolean?
  punchResult     String?
  defenseType     String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([assignmentId])
}
